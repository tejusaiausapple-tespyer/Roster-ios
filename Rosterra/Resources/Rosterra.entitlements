<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  Keychain Sharing — REQUIRED for Firebase Authentication on macOS / Mac
	  Catalyst. FirebaseAuth persists the signed-in session to the keychain, and
	  macOS rejects keychain writes without a keychain access group, surfacing:
	    "An error occurred when accessing the keychain."
	  This also covers the app's own KeychainHelper / BiometricCredentialStore /
	  DeviceAuthService items. `$(AppIdentifierPrefix)` resolves to the signing
	  team prefix, so this works on iOS and Mac Catalyst with a personal or paid
	  team (Keychain Sharing does NOT require a paid membership).
	-->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)com.surainvestments.roster</string>
		<string>$(AppIdentifierPrefix)maccatalyst.com.surainvestments.roster</string>
	</array>


	<!--
	  Associated Domains — required for Apple passkeys (webcredentials scoped to
	  sura-roster.com). Also host apple-app-site-association at
	  https://sura-roster.com/.well-known/apple-app-site-association with a
	  `webcredentials` section listing GS2KGPX9P8.com.surainvestments.roster.
	-->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>webcredentials:sura-roster.com</string>
	</array>

	<!--
	  Push Notifications — production, matching a TestFlight/App Store
	  distribution build. Also enable the Push Notifications capability for
	  this App ID in the Apple Developer portal if not already on by default
	  for a paid-team app.
	-->
	<key>aps-environment</key>
	<string>production</string>
</dict>
</plist>
